# ---- TanoAudit local .env (gitignored) ----
# NOTE: the provider keys below were shared in chat — ROTATE them before any
# real/production use.

# App
APP_ENV=development
APP_NAME="TanoAudit"
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
RATE_LIMIT_ENABLED=true

# Database (local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./tanoaudit.db

# Security (freshly generated for this machine)
JWT_SECRET=eKqRKrVqxMXfk4lTzDpLhRvYTjfq0_TKwYFd0X0yikUDrlE16efQkrU9TjkhE8u4
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
FERNET_KEY=lyM6fcBP-Jzd49wDkUjgG9SHwHiMqivUUhywVBgspeg=

# 2FA
TOTP_ISSUER="TanoAudit"

# Storage / public links (localhost so webhook + handoff URLs resolve)
EXPORT_DIR=./exports
PUBLIC_BASE_URL=http://localhost:8000

# Redis (optional; in-memory fallback if unreachable)
REDIS_URL=rediss://default:gQAAAAAAAkKCAAIgcDE3OTI4YjA1ZTRmZmY0ZWY4OTEyNjk4OGZjNGMyNWNiMA@exotic-mullet-148098.upstash.io:6379

# ---- LLM models ----
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile
# OpenRouter free model — gpt-oss-120b returns clean JSON and was responsive on
# setup. Free models rate-limit often; Auto mode falls back to Gemini regardless.
# Other good free options: openai/gpt-oss-20b:free, qwen/qwen3-coder:free,
# meta-llama/llama-3.3-70b-instruct:free.
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# ---- App-level provider keys ----
