# ---- Akira AI backend environment ----
# Copy to .env and fill in. Never commit the real .env.

# App
APP_ENV=development                 # development | production
APP_NAME="Akira AI"
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database — async SQLAlchemy URL.
# Postgres: postgresql+asyncpg://user:pass@localhost:5432/akira
# SQLite (local dev): sqlite+aiosqlite:///./akira.db
DATABASE_URL=sqlite+aiosqlite:///./akira.db

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# These are VALID, ready-to-run sample secrets so the app boots out of the box.
# Generate your own before any real deployment:  python -m scripts.generate_secrets
JWT_SECRET=qTCDLxME9uk_QKzfCzO1skdPd6V6MVq4mmWFUPtJ_JOTtAix4uiYteBme9rAZmrs
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet key for encrypting user-supplied API keys / OAuth tokens at rest.
# Valid sample key — REGENERATE for production (python -m scripts.generate_secrets).
FERNET_KEY=r0dTkLqpgiVNT8zxh7q9ZcUotDM7FqVTGLrPE4JB_AU=

# 2FA / TOTP
TOTP_ISSUER="Akira AI"

# Rate limiting (login/register/scan/handoff). In-memory, per-process. Set false
# to disable entirely.
RATE_LIMIT_ENABLED=true

# Optional bearer key required on the MCP server (/mcp) when set.
MCP_API_KEY=

# --- LLM access (server-side; users never provide keys) ----------------------
# Server-held provider keys. The app uses these for every user's scans/chat.
# Unset -> that provider is unavailable (scans then return empty results — a
# deploy misconfig). Vendor names are internal only; users pick Akira tiers.
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Concrete model id behind each user-facing Akira tier (override to track
# provider releases without changing the UI). Tier vendor is fixed in code:
# fast=Gemini, balanced/deep=OpenRouter.
TIER_FAST_MODEL=gemini-flash-latest
TIER_BALANCED_MODEL=anthropic/claude-3.5-haiku
TIER_DEEP_MODEL=anthropic/claude-3.7-sonnet

# Per-provider default model ids (used when no tier model applies).
GEMINI_MODEL=gemini-flash-latest
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Hard daily cap on scans per user (rolling 24h). At the cap, scan-create
# returns 429 with seconds-until-reset.
DAILY_SCAN_LIMIT=5

# Storage / public links
EXPORT_DIR=./exports
PUBLIC_BASE_URL=https://akira.ai   # used to build share-link URLs

# Email (Module 15). When SMTP_HOST is unset, emails are logged, not sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Akira AI <no-reply@akira.ai>"
# MailerSend HTTP provider (preferred over SMTP when set).
MAILERSEND_API_KEY=

# Days to keep a scan's cached source files (used for fix/implementation context
# on ZIP/URL scans). Swept daily by the worker.
FILE_CACHE_TTL_DAYS=7
# Input-token budget per analysis request. Segments are batched up to this size
# so a scan makes far fewer LLM calls (critical under tight provider rate limits,
# e.g. Gemini free tier's 25 req/day). Set 0 to disable batching (1 req/segment).
ANALYSIS_BATCH_TOKENS=6000
# How many analysis batches to run concurrently. >1 cuts wall-clock time on big
# scans (the model calls are the slow part). Keep modest to respect provider
# rate limits; 1 = fully sequential.
ANALYSIS_CONCURRENCY=4
# Per-request timeout (seconds) for one analysis LLM call. Bump for slow models
# / large batches; lower to fail faster on a flaky provider.
SEGMENT_TIMEOUT_S=60

# GitHub OAuth app (Module 11). Create one at github.com/settings/developers.
# Without these, GitHub OAuth endpoints return a clear "not configured" 503;
# the rest of the app runs fine.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/github/callback

# Custom-vuln research web search (optional). Tavily is preferred (AI-focused,
# 1,000 free credits/mo — get a key at tavily.com). SerpAPI is a paid fallback.
# With neither set, research uses a deterministic offline stub (OWASP/CWE refs).
TAVILY_KEY=
SERPAPI_KEY=

# SPA origin for OAuth redirects back into the app
FRONTEND_URL=http://localhost:8765
